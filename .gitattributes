# Enforce LF line endings for scripts, Makefile, Go sources, JSON and markdown
*.sh text eol=lf
Makefile text eol=lf
*.go text eol=lf
*.mod text eol=lf
*.sum text eol=lf
*.json text eol=lf
*.md text eol=lf

# Ensure Windows-style binary files are treated as binary
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.gif binary