# Database configuration
DATABASE_DSN=cardman.db
DB_DRIVER=sqlite3

# Logging verbosity: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# SSH server mode: set to true to enable SSH server, false for local TUI
SSH_MODE=false

# SSH server port (only used when SSH_MODE=true)
PORT=8080

# Path to SSH host key file (only used when SSH_MODE=true)
# Generate with: ssh-keygen -t ed25519 -f cardman_host_key -N ""
SSH_HOST_KEY=

# TCGDex API key (optional, but recommended to avoid rate limits)
# Get yours at https://tcgdex.dev/
API_KEY=
